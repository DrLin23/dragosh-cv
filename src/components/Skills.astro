---
import Section from "./Section.astro";

const groups = [
  {
    name: "Languages",
    items: ["C++", "GDScript", "Python", "Java"],
  },
  {
    name: "Tools",
    items: ["Godot", "Aseprite", "Git", "Linux"],
  },
  {
    name: "Practicing",
    items: [
      "Shader programming",
      "Real-time physics",
      "Procedural generation",
    ],
  },
];
---

<Section id="skills" eyebrow="skills" title="What I reach for">
  <div class="grid gap-10 sm:grid-cols-3">
    {
      groups.map((g) => (
        <div>
          <p class="mb-3 font-mono text-xs uppercase tracking-widest text-[color:var(--color-muted)]">
            {g.name}
          </p>
          <ul class="space-y-1.5 font-[family-name:var(--font-display)] text-xl">
            {g.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</Section>
