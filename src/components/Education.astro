---
import Section from "./Section.astro";

const degrees = [
  {
    school: "Vrije Universiteit Amsterdam",
    program: "BSc Computer Science",
    dates: "2023 — 2026 (expected)",
    blurb:
      "Three-year BSc taught in English. Coursework has emphasised object-oriented design, software architecture, and the systems fundamentals relevant to real-time applications and games.",
    highlights: [
      "Software Design — design patterns, SOLID, architecting maintainable systems",
      "Object-Oriented & Functional Programming — mixed-paradigm design, immutability, higher-order abstractions",
      "Data Structures & Algorithms — complexity analysis, graph / tree / sequence algorithms",
      "Linear Algebra — the math behind 3D graphics, transforms, and physics",
      "Computer Organisation — CPU architecture, memory hierarchy, assembly-level reasoning",
      "Operating Systems — processes, scheduling, concurrency, memory management",
      "Systems Programming Project — multi-week team project building systems software from scratch",
    ],
  },
];
---

<Section id="education" eyebrow="Education" title="Where I learned things">
  <ol class="divide-y divide-[color:var(--color-rule)]">
    {
      degrees.map((d) => (
        <li class="grid gap-4 py-8 first:pt-0 last:pb-0 sm:grid-cols-[1fr_2fr]">
          <div>
            <p class="font-medium">{d.school}</p>
            <p class="font-mono text-xs uppercase tracking-widest text-[color:var(--color-muted)]">
              {d.dates}
            </p>
          </div>
          <div class="space-y-4">
            <p class="font-[family-name:var(--font-display)] text-2xl leading-snug">
              {d.program}
            </p>
            <p class="text-[color:var(--color-ink)]/80">{d.blurb}</p>
            <ul class="list-inside list-[square] space-y-1 text-[color:var(--color-muted)] marker:text-[color:var(--color-accent)]">
              {d.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          </div>
        </li>
      ))
    }
  </ol>
</Section>
